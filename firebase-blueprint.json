{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (income or expense).",
      "type": "object",
      "properties": {
        "description": { "type": "string", "description": "Description of the transaction." },
        "amount": { "type": "number", "description": "The amount of the transaction." },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "Type of transaction." },
        "category": { "type": "string", "description": "Category name (internal name)." },
        "date": { "type": "string", "format": "date", "description": "The date of the transaction (YYYY-MM-DD)." },
        "effectiveMonth": { "type": "string", "description": "The month the transaction is effective (YYYY-MM)." },
        "paymentMethod": { "type": "string", "description": "Payment method used (for expenses)." },
        "installments": { "type": "number", "description": "Number of installments (for installment expenses)." },
        "isRecurring": { "type": "boolean", "description": "Whether the transaction is recurring." },
        "expenseNature": { "type": "string", "enum": ["fixed", "variable"], "description": "Nature of the expense." },
        "expenseType": { "type": "string", "enum": ["upfront", "installment", "recurring"], "description": "Type of expense payment." },
        "recurrenceEndDate": { "type": "string", "format": "date", "description": "End date for recurring transactions." },
        "userId": { "type": "string", "description": "The ID of the user who owns this transaction." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when updated." }
      },
      "required": ["description", "amount", "type", "category", "date", "effectiveMonth", "userId"]
    },
    "UserPreferences": {
      "title": "UserPreferences",
      "description": "User's application preferences and custom categories/methods.",
      "type": "object",
      "properties": {
        "language": { "type": "string", "enum": ["en", "pt"], "description": "Preferred language." },
        "selectedCategories": { "type": "array", "items": { "type": "string" }, "description": "List of selected category names." },
        "userDefinedCategories": { "type": "array", "items": { "$ref": "CustomCategoryData" }, "description": "Custom categories defined by the user." },
        "deselectedPredefinedCategories": { "type": "array", "items": { "type": "string" }, "description": "Predefined categories hidden by the user." },
        "selectedPaymentMethods": { "type": "array", "items": { "type": "string" }, "description": "List of selected payment method names." },
        "userDefinedPaymentMethods": { "type": "array", "items": { "$ref": "CustomPaymentMethodData" }, "description": "Custom payment methods defined by the user." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when updated." }
      }
    },
    "CustomCategoryData": {
      "title": "CustomCategoryData",
      "description": "Data for a custom category.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "label": { "type": "object", "properties": { "en": { "type": "string" }, "pt": { "type": "string" } } }
      }
    },
    "CustomPaymentMethodData": {
      "title": "CustomPaymentMethodData",
      "description": "Data for a custom payment method.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "label": { "type": "object", "properties": { "en": { "type": "string" }, "pt": { "type": "string" } } }
      }
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly budget for a specific month.",
      "type": "object",
      "properties": {
        "amount": { "type": "number", "description": "Total budget amount for the month." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when updated." }
      }
    }
  },
  "firestore": {
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User's financial transactions."
    },
    "/users/{userId}/preferences/userPreferences": {
      "schema": "UserPreferences",
      "description": "User's application settings and custom definitions."
    },
    "/users/{userId}/budgets/{monthYear}": {
      "schema": "Budget",
      "description": "User's monthly budgets."
    },
    "/users/{userId}/categories/{categoryId}": {
      "schema": "CustomCategoryData",
      "description": "User's custom categories."
    },
    "/users/{userId}/paymentMethods/{methodId}": {
      "schema": "CustomPaymentMethodData",
      "description": "User's custom payment methods."
    }
  }
}
